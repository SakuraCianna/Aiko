# GLM API 地址
GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4

# GLM 主模型名称
GLM_MODEL=glm-4.6v-flash

# GLM 备用模型列表, 多个模型用逗号分隔
GLM_FALLBACK_MODELS=glm-4v-flash

# GLM API Key
GLM_API_KEY=replace-with-your-api-key

# 是否启用 Tavily MCP 网页搜索
MCP_TAVILY_ENABLED=false

# Tavily MCP 连接模式, 支持 stdio 或 remote
MCP_TAVILY_MODE=stdio

# Tavily MCP stdio 包名
MCP_TAVILY_PACKAGE=tavily-mcp@0.2.19

# Tavily MCP remote 地址
MCP_TAVILY_REMOTE_URL=https://mcp.tavily.com/mcp/

# Tavily 每次搜索最大结果数
MCP_TAVILY_MAX_RESULTS=5

# Tavily 请求超时时间, 单位毫秒
MCP_TAVILY_TIMEOUT_MS=15000

# Tavily 单个 API Key
TAVILY_API_KEY=replace-with-your-tavily-api-key

# Tavily API Key 轮询列表, 多个 Key 用逗号分隔
TAVILY_API_KEYS=replace-with-key-1,replace-with-key-2,replace-with-key-3

# 腾讯云 SecretId, ASR 或 TTS 启用时必填
TENCENTCLOUD_SECRET_ID=replace-with-your-tencent-secret-id

# 腾讯云 SecretKey, ASR 或 TTS 启用时必填
TENCENTCLOUD_SECRET_KEY=replace-with-your-tencent-secret-key

# 腾讯云 AppId, 启用实时 ASR WebSocket 时必填
TENCENTCLOUD_APP_ID=replace-with-your-tencent-app-id

# 腾讯云地域
TENCENTCLOUD_REGION=ap-shanghai

# 是否启用腾讯云 ASR
AIKO_ASR_ENABLED=false

# 是否启用腾讯云实时 ASR WebSocket
AIKO_ASR_REALTIME_ENABLED=false

# ASR provider, 当前固定为 tencent-cloud
AIKO_ASR_PROVIDER=tencent-cloud

# 腾讯云一句话识别引擎
AIKO_ASR_ENGINE_MODEL_TYPE=16k_zh

# ASR 音频格式, 当前麦克风录音默认输出 wav
AIKO_ASR_VOICE_FORMAT=wav

# ASR 识别语言
AIKO_ASR_LANGUAGE=zh

# ASR 请求超时时间, 单位毫秒
AIKO_ASR_TIMEOUT_MS=30000

# 是否启用腾讯云 TTS
AIKO_TTS_ENABLED=false

# TTS provider, 当前固定为 tencent-cloud
AIKO_TTS_PROVIDER=tencent-cloud

# 腾讯云超自然大模型音色编号, 默认邻家女孩
AIKO_TTS_VOICE_TYPE=603007

# 腾讯云音色名称, 仅用于配置展示
AIKO_TTS_VOICE_NAME=邻家女孩

# TTS 音频输出格式
AIKO_TTS_FORMAT=wav

# TTS 音频采样率
AIKO_TTS_SAMPLE_RATE=24000

# TTS 请求超时时间, 单位毫秒
AIKO_TTS_TIMEOUT_MS=30000

# 是否启用 Aiko 主动陪伴心跳
AIKO_COMPANION_ENABLED=true

# 主动陪伴最小间隔, 单位小时
AIKO_COMPANION_INTERVAL_HOURS=24

# 主动陪伴是否使用云端 TTS, 默认关闭以节省额度
AIKO_COMPANION_TTS_ENABLED=false

# 主动陪伴安静时段开始小时, 0 到 23
AIKO_COMPANION_QUIET_START_HOUR=23

# 主动陪伴安静时段结束小时, 0 到 23
AIKO_COMPANION_QUIET_END_HOUR=8
